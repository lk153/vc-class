generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
}

enum AccountStatus {
  INACTIVE
  ACTIVE
}

enum QuestionType {
  MULTIPLE_CHOICE
  GAP_FILL
  REORDER_WORDS
  CUE_WRITING
  PRONUNCIATION
  STRESS
  CLOZE_PASSAGE
  TRUE_FALSE
  MATCHING
  WORD_BANK
}

enum SectionLevel {
  PART
  GROUP
  EXERCISE
}

enum ClassStatus {
  SCHEDULING
  ACTIVE
  ENDED
  CANCELLED
}

enum TestStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ExamSessionStatus {
  DOING
  GRADING
  GRADED
}

enum NotificationType {
  EXAM_SUBMITTED
  EXAM_GRADED
  TEST_ACTIVATED
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  passwordHash    String        @map("password_hash")
  role            UserRole      @default(STUDENT)
  status          AccountStatus @default(INACTIVE)
  learnLanguageId String?       @map("learn_language_id")
  learnLanguage   Language?     @relation(fields: [learnLanguageId], references: [id])
  isTest          Boolean       @default(false) @map("is_test")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  classEnrollments  ClassEnrollment[]
  practiceResults   PracticeResult[]
  studentAnswers    StudentAnswer[]
  flashcardProgress FlashcardProgress[]
  comments          Comment[]
  createdTopics     Topic[]        @relation("TopicCreator")
  createdTests      PracticeTest[] @relation("TestCreator")
  teachingClasses   Class[]        @relation("ClassTeacher")
  media             Media[]
  questionBookmarks QuestionBookmark[]
  examSessions      ExamSession[]
  notifications     Notification[]

  @@map("users")
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  users   User[]
  topics  Topic[]
  classes Class[]

  @@map("languages")
}

model Class {
  id           String      @id @default(cuid())
  name         String
  languageId   String      @map("language_id")
  language     Language    @relation(fields: [languageId], references: [id])
  level        String
  schedule     String
  startDate    DateTime    @map("start_date")
  endDate      DateTime    @map("end_date")
  teacherId    String      @map("teacher_id")
  teacher      User        @relation("ClassTeacher", fields: [teacherId], references: [id])
  maxStudents  Int         @default(10) @map("max_students")
  specialNotes String?     @map("special_notes")
  status       ClassStatus @default(SCHEDULING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  enrollments      ClassEnrollment[]
  topicAssignments TopicAssignment[]

  @@map("classes")
}

model ClassEnrollment {
  id         String   @id @default(cuid())
  classId    String   @map("class_id")
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  @@unique([classId, userId])
  @@map("class_enrollments")
}

model Topic {
  id          String   @id @default(cuid())
  title       String
  description String?
  languageId  String   @map("language_id")
  language    Language @relation(fields: [languageId], references: [id])
  createdById String   @map("created_by_id")
  createdBy   User     @relation("TopicCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vocabulary       Vocabulary[]
  topicAssignments TopicAssignment[]
  practiceTests    PracticeTest[]

  @@map("topics")
}

model Vocabulary {
  id            String   @id @default(cuid())
  word          String
  type          String?  // e.g. "(n)", "(v)", "(adj)"
  pronunciation String?  // e.g. "/kəˈmjuːnɪkeɪt/"
  meaning       String
  example       String?
  topicId       String   @map("topic_id")
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  flashcardProgress FlashcardProgress[]

  @@map("vocabularies")
}

model FlashcardProgress {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyId String     @map("vocabulary_id")
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  learned      Boolean    @default(false)
  learnedAt    DateTime?  @map("learned_at")

  @@unique([userId, vocabularyId])
  @@map("flashcard_progress")
}

model TopicAssignment {
  id         String   @id @default(cuid())
  classId    String   @map("class_id")
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  topicId    String   @map("topic_id")
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([classId, topicId])
  @@map("topic_assignments")
}

model PracticeTest {
  id          String   @id @default(cuid())
  title       String
  topicId     String   @map("topic_id")
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdById String   @map("created_by_id")
  createdBy   User     @relation("TestCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // ── Test configuration ──
  status            TestStatus @default(DRAFT)
  mode              String     @default("test") // "practice" | "test"
  shuffleAnswers    Boolean    @default(false)  @map("shuffle_answers")
  shuffleQuestions  Boolean    @default(false)  @map("shuffle_questions")
  showReviewMoment  Boolean    @default(true)   @map("show_review_moment")
  totalTime         Int        @default(2700)   @map("total_time")
  maxAttempts       Int        @default(1)      @map("max_attempts")
  availableFrom     DateTime?                   @map("available_from")
  availableTo       DateTime?                   @map("available_to")

  questions       Question[]
  practiceResults PracticeResult[]
  sections        TestSection[]
  examSessions    ExamSession[]

  @@map("practice_tests")
}

model TestSection {
  id             String       @id @default(cuid())
  practiceTestId String       @map("practice_test_id")
  practiceTest   PracticeTest @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  parentId       String?      @map("parent_id")
  parent         TestSection? @relation("SectionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       TestSection[] @relation("SectionTree")
  level          SectionLevel
  title          String
  description    String?
  sortOrder      Int          @default(0) @map("sort_order")
  mediaUrl       String?      @map("media_url")
  mediaType      String?      @map("media_type")

  questions      Question[]

  @@map("test_sections")
}

model Question {
  id             String       @id @default(cuid())
  practiceTestId String       @map("practice_test_id")
  practiceTest   PracticeTest @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  questionNumber Int          @map("question_number")
  content        String
  questionType   QuestionType @map("question_type")

  // ── Media on question content ──
  contentMediaUrl  String? @map("content_media_url")
  contentMediaType String? @map("content_media_type")

  answer1 String  @map("answer_1")
  answer2 String? @map("answer_2")
  answer3 String? @map("answer_3")
  answer4 String? @map("answer_4")

  // ── Media on each answer option ──
  answer1MediaUrl  String? @map("answer_1_media_url")
  answer1MediaType String? @map("answer_1_media_type")
  answer2MediaUrl  String? @map("answer_2_media_url")
  answer2MediaType String? @map("answer_2_media_type")
  answer3MediaUrl  String? @map("answer_3_media_url")
  answer3MediaType String? @map("answer_3_media_type")
  answer4MediaUrl  String? @map("answer_4_media_url")
  answer4MediaType String? @map("answer_4_media_type")

  // ── Enhancements ──
  difficulty           Int      @default(1)
  explanation          String?
  explanationMediaUrl  String?  @map("explanation_media_url")
  explanationMediaType String?  @map("explanation_media_type")
  audioPlayLimit       Int?     @map("audio_play_limit")

  correctAnswer String   @map("correct_answer")
  timer         Int      @default(30)
  createdAt     DateTime @default(now()) @map("created_at")

  // ── Section link ──
  sectionId  String?      @map("section_id")
  section    TestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  // ── Advanced question data (JSON) ──
  advancedData  String?  @map("advanced_data")

  // ── Sub-question grouping (CLOZE_PASSAGE blanks) ──
  parentQuestionId  String?    @map("parent_question_id")
  parentQuestion    Question?  @relation("SubQuestions", fields: [parentQuestionId], references: [id], onDelete: Cascade)
  subQuestions      Question[] @relation("SubQuestions")

  studentAnswers StudentAnswer[]
  bookmarks      QuestionBookmark[]

  @@unique([practiceTestId, questionNumber])
  @@map("questions")
}

model PracticeResult {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceTestId String       @map("practice_test_id")
  practiceTest   PracticeTest @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  totalQuestions Int          @map("total_questions")
  correctCount   Int          @map("correct_count")
  incorrectCount Int          @map("incorrect_count")
  score          Float
  completedAt    DateTime     @default(now()) @map("completed_at")

  studentAnswers StudentAnswer[]
  comments       Comment[]
  examSession    ExamSession?

  @@map("practice_results")
}

model StudentAnswer {
  id               String         @id @default(cuid())
  practiceResultId String         @map("practice_result_id")
  practiceResult   PracticeResult @relation(fields: [practiceResultId], references: [id], onDelete: Cascade)
  questionId       String         @map("question_id")
  question         Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId           String         @map("user_id")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedAnswer   String         @map("selected_answer")
  isCorrect        Boolean        @map("is_correct")
  attemptNumber    Int            @default(1) @map("attempt_number")
  timeSpent        Int?           @map("time_spent")
  answeredAt       DateTime       @default(now()) @map("answered_at")

  // ── Teacher grading ──
  teacherOverride  Boolean?       @map("teacher_override")
  teacherScore     Float?         @map("teacher_score")
  teacherComment   String?        @map("teacher_comment")
  teacherGradedAt  DateTime?      @map("teacher_graded_at")

  @@map("student_answers")
}

model Comment {
  id               String         @id @default(cuid())
  content          String
  userId           String         @map("user_id")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceResultId String         @map("practice_result_id")
  practiceResult   PracticeResult @relation(fields: [practiceResultId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@map("comments")
}

model Media {
  id           String   @id @default(cuid())
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  uploadedById String   @map("uploaded_by_id")
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("media")
}

model QuestionBookmark {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, questionId])
  @@map("question_bookmarks")
}

model ExamSession {
  id                String            @id @default(cuid())
  userId            String            @map("user_id")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceTestId    String            @map("practice_test_id")
  practiceTest      PracticeTest      @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  status            ExamSessionStatus @default(DOING)
  attemptNumber     Int               @default(1) @map("attempt_number")

  // ── Progress tracking ──
  currentPhaseIndex Int               @default(0) @map("current_phase_index")
  timeRemaining     Int               @map("time_remaining")
  answersJson       Json              @default("{}") @map("answers_json")
  flaggedJson       Json              @default("[]") @map("flagged_json")

  // ── Exam integrity ──
  tabSwitchCount    Int               @default(0) @map("tab_switch_count")
  ipAddress         String?           @map("ip_address")
  userAgent         String?           @map("user_agent")

  // ── Timestamps ──
  startedAt         DateTime          @default(now()) @map("started_at")
  lastSavedAt       DateTime          @default(now()) @map("last_saved_at")
  submittedAt       DateTime?         @map("submitted_at")
  gradedAt          DateTime?         @map("graded_at")

  // ── Link to final result ──
  practiceResultId  String?           @unique @map("practice_result_id")
  practiceResult    PracticeResult?   @relation(fields: [practiceResultId], references: [id])

  @@unique([userId, practiceTestId, attemptNumber])
  @@map("exam_sessions")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  referenceId String           @map("reference_id")
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}
